# Telemetry server environment -- COPY to server/.env and fill in real values.
# The admin token NEVER goes in the client (open source). Generate strong random
# secrets, e.g.:  openssl rand -hex 32

# Admin auth (HTTP /admin/* + CLI). Empty = admin disabled (fail closed).
ADMIN_TOKEN=change-me-generate-a-strong-random-token

# Salt for hashing client IPs before storage (GDPR: never store the raw IP).
IP_HASH_SALT=change-me-generate-a-strong-random-salt

# SQLite DB path (inside the container -> the dedicated /data volume).
DB_PATH=/data/telemetry.db

# Internal app port (compose binds it to 127.0.0.1 only).
APP_PORT=8081

# App-level rate limit (nginx adds another layer): max submits per window per
# install id (the random per-install UUID, carried as the wire `hwid`) and per IP.
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX=5

# Implausible-jump guard: reject a single submit that grows a counter by more
# than this vs the install's last stored value.
MAX_DELTA_COUNT=100000
MAX_DELTA_RUNTIME_S=172800

# Leaderboard in-process cache TTL (seconds).
CACHE_TTL_S=30

# API docs OFF in prod (set to 1 only for local debugging).
ENABLE_DOCS=0
